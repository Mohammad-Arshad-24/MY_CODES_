class Solution {
    public boolean isHappy(int n) {
        HashMap<Integer,Integer> h = new HashMap<>();
        while (n!=1 && !h.containsKey(n)) {
            h.put(n,1);
            int sum = 0;
            while (n>0) {
                int r=n%10;
                sum+= r*r;
                n/=10;}
            n=sum;
        }
        return n==1;
    }
}
