class Solution {
    public int dominantIndex(int[] nums) {
        int max=nums[0];
        int maxidx=0;
        for(int i=1;i<nums.length;i++){
            if(max<nums[i]){
                max=nums[i];
                maxidx=i;
            }
        }
        for(int i=0;i<nums.length;i++){
            if(i==maxidx){
                continue;
            }
            if(max<nums[i]*2){
                return -1;
            }
        }
        return maxidx;
    }
}
