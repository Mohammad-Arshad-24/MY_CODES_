class Solution {
    public int numJewelsInStones(String jewels, String stones) {
        HashMap<Character,Integer> h=new HashMap<>();
        for(char c : jewels.toCharArray()){
            h.put(c, h.getOrDefault(c,0)+ 1);
        }
        int ct=0;
        for(char c: stones.toCharArray()){
            if(h.containsKey(c)){
                ct++;
            }
        }
        return ct;
    }
}
