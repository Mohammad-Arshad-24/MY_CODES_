class Solution {
    public String firstPalindrome(String[] words) {
        
        for(int i=0;i<words.length;i++){
            String r="";
            String cr=words[i];
            for(char c : cr.toCharArray()){
                r=c+r;
            }
            System.out.println(cr+"    "+r);
            if(r.equals(cr)){
                return cr;
            }
        }
        return "";
    }
}
