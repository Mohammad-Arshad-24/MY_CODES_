class Solution {
    public char findTheDifference(String s, String t) {
        int sum1=0;
        int sum2=0;
        for(char c : s.toCharArray()){
            int curr=(int)c;
            sum1+=curr;
        }
        for(char c : t.toCharArray()){
            int curr=(int)c;
            sum2+=curr;
        }
       
        int f=Math.abs(sum1-sum2);
        char res=(char)f;

return res;
    }
}
