class Solution {
    public int findMaxConsecutiveOnes(int[] nums) {
       int max=0;
       int maxc=0;
       int c=0;
       for(int i : nums){
        if(i==1){
            c++;
            maxc=Math.max(maxc,c);
        }
        else{
            c=0;
        }
       }
       return maxc;
    }
}
