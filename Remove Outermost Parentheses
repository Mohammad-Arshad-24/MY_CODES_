class Solution {
    public String removeOuterParentheses(String s) {
        String res = "";
        int c = 0;
        for (int i=0;i<s.length();i++) {
            if (s.charAt(i)=='(') {
                if (c>0) {
                    res+="(";
                }
                c++;
            } else {
                c--;
                if (c>0) {
                    res+=")";
                }
            }
        }
        return res;
    }
}
