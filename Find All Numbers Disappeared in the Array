class Solution {
    public List<Integer> findDisappearedNumbers(int[] nums) {
    HashMap<Integer, Integer> h = new HashMap<>();
        for (int num : nums) {
            h.put(num, 1);}
        ArrayList<Integer> res = new ArrayList<>();
        for (int i = 1; i <= nums.length; i++) {
            if (!h.containsKey(i)) {
                res.add(i);
            }
        }
        return res;
    }
}
