class Solution {
    public String reverseStr(String s, int k) {
        char [] res= s.toCharArray();
        for(int i=0;i<s.length();i+=2*k){
            int l=i;
            int r=Math.min(i+k-1,s.length()-1);
            while(l<r){
                char temp=res[l];
                res[l]=res[r];
                res[r]=temp;
                l++;
                r--;
            }
        }
        return new String(res);
    }
}
