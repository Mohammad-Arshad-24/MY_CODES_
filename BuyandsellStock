class Solution:
    def maxProfit(self, prices: List[int]) -> int:
        chk_till = len(prices)
        min_price = prices[0]
        max_profit = 0

        for i in range(1, chk_till):
            if prices[i] < min_price:
                min_price = prices[i]
            profit = prices[i] - min_price
            if profit > max_profit:
                max_profit = profit

        return max_profit
