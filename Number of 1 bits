class Solution {
    public int hammingWeight(int n) {
       String bin="";
       while(n>0){
            int rem=n%2;
            bin=rem+bin;
            n=n/2;
       } 
       char[] c=bin.toCharArray();
       int k=0;
       for(char ch :c){
        if(ch=='1'){
            k++;
        }
       }
       return k;
    }
}
