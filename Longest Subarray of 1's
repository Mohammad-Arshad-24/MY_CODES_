class Solution {
    public int longestSubarray(int[] nums) {
        int s=0;

        int max=0,count=0;
        for(int e=0;e<nums.length;e++){
            if(nums[e]==0){
                count++;
            }
            while(count>1){
                if(nums[s]==0){
                    count--;
                }
                s++;
            }
            max=Math.max(max,e-s);
        }
        return max;
            }
}
