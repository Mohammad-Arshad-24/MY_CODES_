class Solution {
    public String reversePrefix(String word, char ch) {
       char[] res = word.toCharArray();
        for(int i =0;i < word.length();i++){
            if(word.charAt(i)==ch){
                int c=0;
            for(int j=i;j>=0;j--){
               res[c]=word.charAt(j);
                c++;
            }
            break;
            }
        }
        return new String(res);
    }
}
