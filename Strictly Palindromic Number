class Solution {
    public boolean isStrictlyPalindromic(int n) {
        for(int i=2;i<=n-2;i++){
            String b = Integer.toString(n,i);
            int l=0;
            int r=b.length()-1;
            while(l<=r){
                if(b.charAt(l)!=b.charAt(r)){
                    return false;
                }
                l++;
                r--;
            }
        }
        return true;
    }
}
