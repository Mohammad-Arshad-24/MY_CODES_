class Solution {
    public int reverse(int x) {

        int rev=0,res=0;
        while(x!=0){
                    if (res > Integer.MAX_VALUE / 10 || res < Integer.MIN_VALUE / 10) {
    return 0;
}
            rev=x%10;
            res=res*10+rev;
            x=x/10;
        }
        return res;
    }
}
