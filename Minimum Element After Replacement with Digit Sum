class Solution {
    public int minElement(int[] nums) {
        int min=Integer.MAX_VALUE;
        for(int n : nums){
            int sum=0;
            int curr=n;
            while(n>0){
                curr=n%10;
                sum+=curr;
                n/=10;
            }
            if(min>sum){
                min=sum;
            }
        }
        return min;
    }
}
