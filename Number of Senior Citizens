class Solution {
    public int countSeniors(String[] details) {
        int c=0;
        for(int i=0;i<details.length;i++){
            String curr=details[i];
            String age="";
            age=""+curr.charAt(11)+curr.charAt(12);
             int a=Integer.parseInt(age);
             if(a>60){
                c++;
             }
        }
        return c;
    }
}
