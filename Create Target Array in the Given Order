class Solution {
    public int[] createTargetArray(int[] nums, int[] index) {
        ArrayList<Integer> a=new ArrayList<>();
        for(int n : nums){
            a.add(n);
        }
        for(int i=0;i<nums.length;i++){
            a.add(index[i],nums[i]);
        }
        for(int i=0;i<nums.length;i++){
            nums[i]=a.get(i);
        }
        return nums;
    }
}
