class Solution {
    public int canBeTypedWords(String text, String brokenLetters) {
        String[] words = text.split(" ");
        int count = 0;
        for (String word : words) {
            boolean ok = true;
            for (int i = 0; i < word.length(); i++) {
                if (brokenLetters.contains("" + word.charAt(i))) {
                    ok = false;
                    break;
                }
            }
            if (ok) {
                count++;
            }
        }
        return count;
    }
}
