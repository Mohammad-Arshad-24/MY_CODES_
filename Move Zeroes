class Solution {
    public void moveZeroes(int[] nums) {
        int l=nums.length;
        int[] res=new int[l];
        int c=0;
        for(int i=0;i<l;i++){
            if(nums[i]!=0){
                res[c]=nums[i];
                c++;
            }
        }
        for(int i=c;i<nums.length;i++){
            res[i]=0;
        }
        for(int i=0;i<l;i++){
            nums[i]=res[i];
        }
        
    }
}
