class Solution {
    public int findComplement(int num) {
        String a="";
        while(num>=1){
            int r=num%2;
            if(r==0){r=1;}
            else{r=0;}
            a=r+a;
            num=num/2;
        }
        int res=0;
        int c=0;
        for(int i = a.length()-1;i>=0;i--){
            if(a.charAt(i)  =='1' ){
                res+=Math.pow(2,c);
            }
            c++;
        }
        return res;
    }
}
